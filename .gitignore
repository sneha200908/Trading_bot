# ──────────────────────────────────────────────────────────────
# .gitignore — Binance Futures Trading Bot
# ──────────────────────────────────────────────────────────────

# ─── Environment & Secrets ───────────────────────────────────
.env
!.env.example

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg-info/
*.egg
dist/
build/
*.whl

# ─── Virtual Environments ───────────────────────────────────
venv/
.venv/
env/
ENV/

# ─── Logs ────────────────────────────────────────────────────
logs/*.log
logs/*.log.*

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Testing ─────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/

# ─── Misc ────────────────────────────────────────────────────
*.bak
*.tmp
